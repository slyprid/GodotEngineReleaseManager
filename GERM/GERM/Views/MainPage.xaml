<Page
    x:Class="GERM.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:GERM.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">


    <Grid Padding="16" RowSpacing="12" ColumnSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Destination Directory:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1"
                 Text="{x:Bind ViewModel.DestinationDirectory, Mode=TwoWay}"
                 PlaceholderText="e.g. C:\Output\Builds"
                 MinHeight="32"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Platform:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="1" Grid.Column="1"
                  ItemsSource="{x:Bind ViewModel.Platforms}"
                  SelectedItem="{x:Bind ViewModel.SelectedPlatform, Mode=TwoWay}"
                  MinHeight="32"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="2" Grid.Column="1"
                  ItemsSource="{x:Bind ViewModel.Types}"
                  SelectedItem="{x:Bind ViewModel.SelectedType, Mode=TwoWay}"
                  MinHeight="32"/>

        <Button Grid.Row="3" Grid.Column="1"
                Content="Run"
                HorizontalAlignment="Left"
                Command="{x:Bind ViewModel.RunCommand}"
                IsEnabled="{x:Bind !ViewModel.IsBusy}"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Output:" VerticalAlignment="Top"/>
        <TextBox Grid.Row="4" Grid.Column="1"
                 Text="{x:Bind ViewModel.Output, Mode=TwoWay}"
                 AcceptsReturn="True"
                 TextWrapping="Wrap"
                 IsReadOnly="True"
                 FontFamily="Consolas"
                 FontSize="12"
                 Padding="8"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"/>

        <ProgressBar Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                     Minimum="0" Maximum="100"
                     Value="{x:Bind ViewModel.Progress, Mode=OneWay}"
                     Height="18"
                     Margin="0,8,0,0"/>
    </Grid>

</Page>